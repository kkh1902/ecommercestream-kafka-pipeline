# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=clickstream

# File Paths
CSV_FILE_PATH=data/raw/events.csv
BACKUP_DIR=data/raw/backup

# Producer Settings
PRODUCER_INTERVAL=4

# Consumer Settings
CONSUMER_GROUP_ID=ecommerce_consumer_group

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ecommerce
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123

# Slack Alert Configuration
# Slack Webhook URL 설정: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_ALERT_ENABLED=false

# Email Alert Configuration
# Gmail 사용 시: https://myaccount.google.com/apppasswords 에서 앱 비밀번호 생성
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_FROM=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_TO=recipient@example.com